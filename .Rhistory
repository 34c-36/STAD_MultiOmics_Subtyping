# 步骤1
#检查并安装BiocManager
if (!require("BiocManager", quietly = TRUE)) install.packages("BiocManager")
# 定义需要的包列表
packages <- c(
"tidyverse", "data.table", "pheatmap", "ggpubr", "factoextra", "cluster",
"limma", "impute", "ConsensusClusterPlus", "survival", "survminer",
"mixOmics", "SNFtool", "clusterProfiler", "org.Hs.eg.db"
)
# 循环安装缺失的包
for (pkg in packages) {
if (!require(pkg, quietly = TRUE, character.only = TRUE)) {
if (pkg %in% c("limma", "impute", "ConsensusClusterPlus", "clusterProfiler", "org.Hs.eg.db")) {
BiocManager::install(pkg, ask = FALSE)
} else {
install.packages(pkg, repos = "https://mirrors.tuna.tsinghua.edu.cn/CRAN/")
}
}
}
# 加载所有包
lapply(packages, library, character.only = TRUE)
cat("所有包安装/加载完成！\n")
#步骤2
# 检查8个数据文件是否存在
file_list <- c(
"STAD_mc3_gene_level.txt",
"Gistic2_CopyNumber_Gistic2_all_thresholded.by_genes",
"HumanMethylation450",
"HiSeqV2",
"miRNA_HiSeq_gene",
"RPPA",
"TCGA.STAD.sampleMap_STAD_clinicalMatrix",
"survival_STAD_survival.txt"
)
# 检查缺失的文件
missing_files <- file_list[!file.exists(file_list)]
if (length(missing_files) > 0) {
stop("缺失以下文件，请检查文件名：\n", paste(missing_files, collapse = "\n"))
} else {
cat("所有8个数据文件检查通过！\n")
}
#步骤3
#读取数据并进行样本名标准化和匹配
cat("正在读取数据...\n")
# 修读取矩阵函数
read_matrix <- function(file_name) {
# 1. 先用fread读取文件
dt <- fread(file_name, header = TRUE, sep = "\t", check.names = FALSE)
# 2. 手动把第一列设为行名
mat <- as.matrix(dt[, -1]) # 去掉第一列，剩下的内容转矩阵
rownames(mat) <- dt[[1]]  
return(mat)
}
mut_data <- read_matrix("STAD_mc3_gene_level.txt")
cnv_data <- read_matrix("Gistic2_CopyNumber_Gistic2_all_thresholded.by_genes")
meth_data <- read_matrix("HumanMethylation450")
rna_data <- read_matrix("HiSeqV2")
mirna_data <- read_matrix("miRNA_HiSeq_gene")
rppa_data <- read_matrix("RPPA")
# 读取临床和生存数据
clinical_data <- fread("TCGA.STAD.sampleMap_STAD_clinicalMatrix", header = TRUE, sep = "\t", data.table = FALSE)
surv_data <- fread("survival_STAD_survival.txt", header = TRUE, sep = "\t", data.table = FALSE)
# 把临床/生存数据的第一列设为行名
rownames(clinical_data) <- clinical_data[[1]]
clinical_data <- clinical_data[, -1]
rownames(surv_data) <- surv_data[[1]]
surv_data <- surv_data[, -1]
# 样本名标准化函数
format_sample_id <- function(ids) {
ids <- gsub("\\.", "-", ids) 
ids <- substr(ids, 1, 15)    
return(ids)
}
# 对所有数据的样本名执行标准化
colnames(mut_data) <- format_sample_id(colnames(mut_data))
colnames(cnv_data) <- format_sample_id(colnames(cnv_data))
colnames(meth_data) <- format_sample_id(colnames(meth_data))
colnames(rna_data) <- format_sample_id(colnames(rna_data))
colnames(mirna_data) <- format_sample_id(colnames(mirna_data))
colnames(rppa_data) <- format_sample_id(colnames(rppa_data))
rownames(clinical_data) <- format_sample_id(rownames(clinical_data))
rownames(surv_data) <- format_sample_id(rownames(surv_data))
# 筛选原发肿瘤样本 + 取共有样本
is_tumor <- function(ids) substr(ids, 14, 15) == "01"
# 提取每组的肿瘤样本ID
sample_sets <- list(
mut = colnames(mut_data)[is_tumor(colnames(mut_data))],
cnv = colnames(cnv_data)[is_tumor(colnames(cnv_data))],
meth = colnames(meth_data)[is_tumor(colnames(meth_data))],
rna = colnames(rna_data)[is_tumor(colnames(rna_data))],
mirna = colnames(mirna_data)[is_tumor(colnames(mirna_data))],
rppa = colnames(rppa_data)[is_tumor(colnames(rppa_data))],
clinical = rownames(clinical_data)[is_tumor(rownames(clinical_data))],
surv = rownames(surv_data)[is_tumor(rownames(surv_data))]
)
# 取所有数据的共有样本
common_samples <- Reduce(intersect, sample_sets)
cat("最终分析样本数：", length(common_samples), "\n")
# 按共有样本截取所有矩阵
mut_data <- mut_data[, common_samples]
cnv_data <- cnv_data[, common_samples]
meth_data <- meth_data[, common_samples]
rna_data <- rna_data[, common_samples]
mirna_data <- mirna_data[, common_samples]
rppa_data <- rppa_data[, common_samples]
clinical_data <- clinical_data[common_samples, ]
surv_data <- surv_data[common_samples, ]
cat("数据读取与样本匹配完成！\n")
#步骤4
cat("正在进行数据预处理...\n")
# 1. 突变数据过滤
mut_freq <- rowSums(mut_data == 1, na.rm = TRUE) / ncol(mut_data)
mut_filtered <- mut_data[mut_freq >= 0.05, ]
cat("突变数据：保留", nrow(mut_filtered), "个基因\n")
# 2. CNV数据过滤
cnv_freq <- rowSums(abs(cnv_data) >= 1, na.rm = TRUE) / ncol(cnv_data)
cnv_filtered <- cnv_data[cnv_freq >= 0.03, ]
cat("CNV数据：保留", nrow(cnv_filtered), "个基因\n")
# 3. 甲基化数据过滤
meth_na <- rowSums(is.na(meth_data)) / ncol(meth_data)
meth_filtered <- meth_data[meth_na <= 0.1, ]
cat("正在填充甲基化缺失值...\n")
meth_filtered <- impute.knn(meth_filtered, k = 5)$data
meth_var <- apply(meth_filtered, 1, var, na.rm = TRUE)
meth_filtered <- meth_filtered[!is.na(meth_var), ]
meth_var <- meth_var[!is.na(meth_var)]
meth_filtered <- meth_filtered[meth_var >= quantile(meth_var, 0.7, na.rm = TRUE), ]
cat("甲基化数据：保留", nrow(meth_filtered), "个探针\n")
# 表达数据过滤函数 
filter_exp <- function(exp_mat) {
zero_rate <- rowSums(exp_mat == 0, na.rm = TRUE) / ncol(exp_mat)
exp_mat <- exp_mat[zero_rate <= 0.5, ]
exp_var <- apply(exp_mat, 1, var, na.rm = TRUE)
exp_mat <- exp_mat[!is.na(exp_var), ]
exp_var <- exp_var[!is.na(exp_var)]
if(length(exp_var) == 0) return(exp_mat)
exp_mat <- exp_mat[exp_var >= quantile(exp_var, 0.75, na.rm = TRUE), ]
exp_mat <- t(scale(t(exp_mat)))
exp_mat[is.na(exp_mat)] <- 0
return(exp_mat)
}
# 执行过滤
rna_filtered <- filter_exp(rna_data)
mirna_filtered <- filter_exp(mirna_data)
rppa_filtered <- filter_exp(rppa_data)
cat("mRNA数据：保留", nrow(rna_filtered), "个基因\n")
cat("miRNA数据：保留", nrow(mirna_filtered), "个miRNA\n")
cat("蛋白数据：保留", nrow(rppa_filtered), "个蛋白\n")
# 保存结果
save(
mut_filtered, cnv_filtered, meth_filtered,
rna_filtered, mirna_filtered, rppa_filtered,
clinical_data, surv_data, common_samples,
file = "1_预处理结果.RData"
)
cat("预处理完成！结果已保存为 1_预处理结果.RData\n")
#步骤5
# 加载预处理结果
load("1_预处理结果.RData")
library(SNFtool)
library(cluster)
set.seed(123456) # 固定种子，保证结果可复现
cat("正在进行多组学整合分型...\n")
# 1. 构建组学相似性矩阵
build_sim <- function(data_mat) {
dist_mat <- dist2(t(data_mat), t(data_mat))
sigma <- median(dist_mat) * 0.5
sim_mat <- exp(-dist_mat^2 / (2 * sigma^2))
return(sim_mat)
}
sim_list <- list(
mut = build_sim(mut_filtered),
cnv = build_sim(cnv_filtered),
meth = build_sim(meth_filtered),
rna = build_sim(rna_filtered),
mirna = build_sim(mirna_filtered),
rppa = build_sim(rppa_filtered)
)
# 2. 相似性网络融合
fused_network <- SNF(sim_list, K = 20, t = 20)
# 3. 确定最优聚类数K（用轮廓系数）
sil_scores <- numeric(8)
sil_scores[1] <- NA # K从2开始
for (k in 2:8) {
clusters <- spectralClustering(fused_network, k)
sil <- silhouette(clusters, dist(1 - fused_network))
sil_scores[k] <- mean(sil[, 3])
}
# 绘制轮廓系数图
pdf("2_最优聚类数选择.pdf", width = 8, height = 5)
plot(2:8, sil_scores[2:8], type = "b", pch = 16, xlab = "聚类数 K", ylab = "平均轮廓系数", main = "多组学整合最优聚类数选择")
points(which.max(sil_scores), sil_scores[which.max(sil_scores)], col = "red", pch = 16, cex = 1.5)
dev.off()
optimal_K <- which.max(sil_scores)
cat("最优聚类数 K =", optimal_K, "\n")
# 4. 提取最终分型结果
final_subtypes <- spectralClustering(fused_network, optimal_K)
names(final_subtypes) <- common_samples
final_subtypes <- factor(paste0("亚型", final_subtypes), levels = paste0("亚型", 1:optimal_K))
# 输出各亚型样本数
print(table(final_subtypes))
# 保存分型结果
save(final_subtypes, fused_network, file = "2_分型结果.RData")
cat("多组学分型完成！结果已保存为 2_分型结果.RData\n")
#步骤6
library(SNFtool)
library(cluster)
library(survival)
library(survminer)
library(pheatmap)
set.seed(123456)
# 加载结果
load("1_预处理结果.RData")
load("2_分型结果.RData")
cat("正在生成验证结果与可视化...\n")
#  最优聚类数选择图
sil_scores <- numeric(8)
sil_scores[1] <- NA
for (k in 2:8) {
clusters <- spectralClustering(fused_network, k)
sil <- silhouette(clusters, dist(1 - fused_network))
sil_scores[k] <- mean(sil[, 3])
}
cairo_pdf("2_最优聚类数选择.pdf", width = 8, height = 5, family = "sans")
plot(2:8, sil_scores[2:8], type = "b", pch = 16, lwd = 2,
xlab = "Number of Clusters (K)", ylab = "Mean Silhouette Score",
main = "Optimal Clustering Number Selection", xlim = c(2,8), xaxt = "n")
axis(1, at = 2:8, labels = 2:8)
points(which.max(sil_scores), sil_scores[which.max(sil_scores)], col = "red", pch = 16, cex = 1.5)
dev.off()
cat("最优聚类数图已保存为 2_最优聚类数选择.pdf\n")
# 1. 生存预后分析（OS总生存）
surv_df <- data.frame(
Subtype = final_subtypes,
OS = as.numeric(surv_data$OS),
OS_time = as.numeric(surv_data$OS.time)
)
km_fit <- survfit(Surv(OS_time, OS) ~ Subtype, data = surv_df)
cairo_pdf("3_生存分析曲线.pdf", width = 12, height = 8, family = "sans")
print(ggsurvplot(
km_fit, pval = TRUE, risk.table = TRUE,
palette = "jco", legend.title = "Multi-omics Subtype",
xlab = "Survival Time (days)", ylab = "Overall Survival Rate (OS)",
xlim = c(0, 4000), break.time.by = 1000,
legend.labs = paste0("Subtype ", 1:8),
ggtheme = theme_minimal()
))
dev.off()
cat("生存曲线已保存为 3_生存分析曲线.pdf\n")
# 2. 多组学特征热图
top_genes <- names(sort(apply(rna_filtered, 1, var), decreasing = TRUE))[1:100]
heatmap_mat <- rna_filtered[top_genes, ]
heatmap_mat <- heatmap_mat[, order(final_subtypes)]
annot_df <- data.frame(Subtype = final_subtypes[order(final_subtypes)])
rownames(annot_df) <- colnames(heatmap_mat)
cairo_pdf("4_多组学特征热图.pdf", width = 16, height = 10, family = "sans")
pheatmap(
heatmap_mat, annotation_col = annot_df, scale = "row",
show_rownames = FALSE, show_colnames = FALSE, treeheight_col = 20,
main = "Multi-omics Subtype Gene Expression Heatmap",
color = colorRampPalette(c("navy","white","firebrick3"))(100)
)
dev.off()
cat("特征热图已保存为 4_多组学特征热图.pdf\n")
# 3. 与TCGA经典分型关联
mut_burden <- colSums(mut_filtered == 1)
cnv_burden <- colSums(abs(cnv_filtered) >= 1)
tcga_like <- rep("CIN", length(common_samples))
tcga_like[mut_burden > median(mut_burden) + 2*sd(mut_burden)] <- "MSI"
tcga_like[mut_burden < median(mut_burden) & cnv_burden < median(cnv_burden)] <- "GS"
tcga_like <- factor(tcga_like, levels = c("MSI", "GS", "CIN"))
cont_table <- table(final_subtypes, tcga_like)
rownames(cont_table) <- paste0("Subtype ", 1:nrow(cont_table))
cairo_pdf("5_与TCGA分型关联_最终修复版.pdf", width = 10, height = 7, family = "Arial")
pheatmap(
cont_table,
display_numbers = TRUE,
scale = "row",
main = "Subtypes vs TCGA Classical Subtypes Correlation Heatmap",
fontsize = 11,
fontsize_row = 10,  
fontsize_col = 10,  
angle_col = 45,     
angle_row = 0,      
treeheight_row = 15,
treeheight_col = 15,
color = colorRampPalette(c("navy", "white", "firebrick3"))(20),
border_color = "white" 
)
dev.off()
cat("生成新文件：5_与TCGA分型关联.pdf\n")
cat(" spectralClustering函数已正常加载，所有图表生成完成！\n")